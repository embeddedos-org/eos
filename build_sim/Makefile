# target to generate assembly for a file
net/src/net.c.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/eos_net.dir/build.make CMakeFiles/eos_net.dir/net/src/net.c.s
.PHONY : net/src/net.c.s

power/src/power.o: power/src/power.c.o
.PHONY : power/src/power.o

# target to build an object file
power/src/power.c.o:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/eos_power.dir/build.make CMakeFiles/eos_power.dir/power/src/power.c.o
.PHONY : power/src/power.c.o

power/src/power.i: power/src/power.c.i
.PHONY : power/src/power.i

# target to preprocess a source file
power/src/power.c.i:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/eos_power.dir/build.make CMakeFiles/eos_power.dir/power/src/power.c.i
.PHONY : power/src/power.c.i

power/src/power.s: power/src/power.c.s
.PHONY : power/src/power.s

